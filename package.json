{
    "name": "claudehydra-v4",
    "private": true,
    "version": "4.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "biome check src/",
        "lint:fix": "biome check --write src/",
        "format": "biome format --write src/",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:visual": "node scripts/watchdog-visual.mjs",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "e2e:headed": "playwright test --headed",
        "e2e:debug": "playwright test --debug",
        "e2e:report": "playwright show-report",
        "preview": "vite preview",
        "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
        "prepare": "husky",
        "typecheck": "tsc --noEmit",
        "analyze": "vite build --mode analyze"
    },
    "dependencies": {
        "@jaskier/chat-module": "workspace:*",
        "@jaskier/core": "workspace:*",
        "@jaskier/hydra-app": "workspace:*",
        "@jaskier/i18n": "workspace:*",
        "@jaskier/state": "workspace:*",
        "@jaskier/ui": "workspace:*",
        "@jaskier/vault-client": "workspace:*",
        "@jaskier/wasm-worker": "workspace:*",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-virtual": "^3.13.21",
        "@types/d3": "^7.4.3",
        "@xyflow/react": "^12.10.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "d3": "^7.9.0",
        "dompurify": "^3.3.2",
        "highlight.js": "^11.11.1",
        "i18next": "^25.8.14",
        "i18next-browser-languagedetector": "^8.2.1",
        "lucide-react": "^0.575.0",
        "motion": "^12.35.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.6",
        "react-markdown": "^10.1.0",
        "recharts": "^3.8.0",
        "rehype-highlight": "^7.0.2",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "web-vitals": "^5.1.0",
        "y-websocket": "^2.1.0",
        "yjs": "^13.6.24",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@jaskier/eslint-config": "workspace:*",
        "@jaskier/testing": "workspace:*",
        "@jaskier/typescript-config": "workspace:*",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.2.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.3.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "conventional-changelog-cli": "^5.0.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.3.2",
        "node-fetch": "^3.3.2",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^6.2.0",
        "vite-plugin-pwa": "^0.21.0",
        "vite-plugin-top-level-await": "^1.4.4",
        "vite-plugin-wasm": "^3.5.0",
        "vitest": "^4.0.18"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "node ./node_modules/@biomejs/biome/bin/biome check --write",
            "node ./node_modules/@biomejs/biome/bin/biome format --write"
        ],
        "*.css": [
            "node ./node_modules/@biomejs/biome/bin/biome format --write"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "@jaskier/ui"
        ],
        "overrides": {
            "@conventional-changelog/git-client": ">=2.0.0",
            "undici": ">=7.24.0",
            "serialize-javascript": ">=7.0.3"
        }
    },
    "overrides": {
        "undici": ">=7.24.0",
        "serialize-javascript": ">=7.0.3"
    }
}
