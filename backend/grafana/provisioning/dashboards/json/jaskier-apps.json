{
  "uid": "jaskier-apps",
  "title": "Jaskier Apps Overview",
  "tags": ["fly.io", "jaskier"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
        "query": "label_values(fly_app_http_responses_count, app)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "App Status (up)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "up{app=~\"$app\"}",
          "legendFormat": "{{app}} ({{instance}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "options": { "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 2,
      "title": "HTTP Requests Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "sum(rate(fly_app_http_responses_count{app=~\"$app\"}[5m])) by (app, status)",
          "legendFormat": "{{app}} - {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "fly_instance_memory_mem_total{app=~\"$app\"} - fly_instance_memory_mem_available{app=~\"$app\"}",
          "legendFormat": "{{app}} used"
        },
        {
          "expr": "fly_instance_memory_mem_total{app=~\"$app\"}",
          "legendFormat": "{{app}} total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "rate(fly_instance_cpu{app=~\"$app\"}[5m])",
          "legendFormat": "{{app}} ({{instance}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 5,
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fly_app_http_response_time_seconds_bucket{app=~\"$app\"}[5m])) by (app, le))",
          "legendFormat": "{{app}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "rate(fly_instance_net_sent_bytes{app=~\"$app\"}[5m])",
          "legendFormat": "{{app}} sent"
        },
        {
          "expr": "rate(fly_instance_net_recv_bytes{app=~\"$app\"}[5m])",
          "legendFormat": "{{app}} recv"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 7,
      "title": "Database Connections (jaskier-db)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "P2F9D94EF368BDA71" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{app=\"jaskier-db\"}",
          "legendFormat": "{{datname}} ({{state}})"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
